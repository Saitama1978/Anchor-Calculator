<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anchor Calculator</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background-color: #121B22; color: #E9EDEF; padding: 15px; margin: 0; }
        .card { background-color: #1F2C34; padding: 20px; border-radius: 12px; max-width: 450px; margin: 20px auto; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }
        h2 { text-align: center; color: #00A884; margin-top: 0; font-size: 22px; border-bottom: 1px solid #2A3942; padding-bottom: 10px; }
        label { display: block; margin-top: 15px; font-size: 14px; color: #8696A0; }
        input { width: 100%; padding: 12px; margin-top: 5px; background-color: #2A3942; border: 1px solid #3B4A54; border-radius: 8px; color: white; font-size: 16px; box-sizing: border-box; }
        input:focus { border-color: #00A884; outline: none; }
        button { width: 100%; background-color: #00A884; color: #111B21; border: none; padding: 14px; border-radius: 8px; font-size: 16px; font-weight: bold; margin-top: 25px; cursor: pointer; transition: 0.2s; }
        button:active { background-color: #008F72; }
        .result-box { display: none; background-color: #2A3942; padding: 15px; border-radius: 8px; margin-top: 20px; border-left: 5px solid #00A884; }
        .result-line { margin: 8px 0; font-size: 16px; }
        .warning { border-left-color: #EA0038; color: #FF8A8A; }
        .success { border-left-color: #00A884; color: #81E6D9; }
        .heavy { border-left-color: #3498DB; color: #90CAF9; }
    </style>
</head>
<body>

<div class="card">
    <h2>⚓ Anchor Scope & Turning Circle</h2>
    
    <label>Water Depth (Meters):</label>
    <input type="number" id="depth" placeholder="Enter depth..." value="20">

    <label>Ship's LOA (Meters):</label>
    <input type="number" id="loa" placeholder="Enter LOA..." value="180">

    <label>Shackles to Let Go:</label>
    <input type="number" id="shackles" placeholder="Enter shackles..." value="7">

    <button onclick="calculateMetrics()">CALCULATE</button>

    <div class="result-box" id="resultBox">
        <div class="result-line" id="totalChain" style="font-weight: bold;"></div>
        <div class="result-line" id="turningRadius" style="font-weight: bold; font-size: 18px; color: #FFF;"></div>
        <div class="result-line" id="statusMessage" style="margin-top: 12px; font-size: 14px;"></div>
    </div>
</div>

<script>
function calculateMetrics() {
    let depth = parseFloat(document.getElementById('depth').value) || 0;
    let loa = parseFloat(document.getElementById('loa').value) || 0;
    let shackles = parseFloat(document.getElementById('shackles').value) || 0;
    
    if(depth <= 0 || loa <= 0 || shackles <= 0) {
        alert("Paki-kumpleto ang mga detalye.");
        return;
    }

    let chainMeters = shackles * 27.5;
    let radius = chainMeters + loa;
    let scope = chainMeters / depth;

    document.getElementById('totalChain').innerText = "Total Chain in Water: " + chainMeters + " m";
    document.getElementById('turningRadius').innerText = "Swinging Radius: " + radius + " m";
    
    let box = document.getElementById('resultBox');
    let msg = document.getElementById('statusMessage');
    box.className = "result-box"; 

    if (scope < 3) {
        box.classList.add("warning");
        msg.innerText = "⚠️ WARNING: Masyadong maikli ang kadena! (Scope Ratio: " + scope.toFixed(1) + ")";
    } else if (scope >= 3 && scope <= 5) {
        box.classList.add("success");
        msg.innerText = "✅ SAFE: Maganda ang kapit para sa Good Weather. (Scope Ratio: " + scope.toFixed(1) + ")";
    } else {
        box.classList.add("heavy");
        msg.innerText = "🌊 HEAVY SCOPE: Ligtas para sa Rough Weather. (Scope Ratio: " + scope.toFixed(1) + ")";
    }
    
    box.style.display = "block";
}
</script>

</body>
</html>
